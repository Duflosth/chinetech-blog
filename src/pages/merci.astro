---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Merci - CHINETECH" description="Confirmation d'inscription à la newsletter CHINETECH.">
  <main class="page-main">
    <section class="page-hero page-hero--center shell reveal">
      <p class="eyebrow">Signal reçu</p>
      <h1>Merci</h1>
      <p>Votre inscription à la newsletter est bien prise en compte.</p>
      <div class="hero__actions hero__actions--center">
        <a class="button button--cyan" href="/">Retour à l'accueil</a>
        <a class="button" href="/articles/">Lire les articles</a>
      </div>
    </section>
  </main>
</BaseLayout>
