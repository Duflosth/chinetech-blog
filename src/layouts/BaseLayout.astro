---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CHINETECH - Blog tech Chine',
  description = "Analyses, tendances et signaux faibles de l'écosystème technologique chinois."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="shell topbar__inner">
        <a class="brand" href="/#top" aria-label="CHINETECH accueil">
          <span class="brand__name">CHINETECH</span>
          <span class="brand__tag">科技中国</span>
        </a>

        <nav class="nav" aria-label="Navigation principale">
          <a href="/#top">Accueil</a>
          <a href="/#featured">Tech</a>
          <a href="/#topics">Chine</a>
          <a href="/articles/">Articles</a>
          <a href="/#subscribe">Newsletter</a>
          <a href="#footer">À propos</a>
        </nav>

        <div class="icon-row" aria-hidden="true">
          <button class="icon-button" type="button" aria-label="Recherche">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"></circle><path d="m16.5 16.5 4 4"></path></svg>
          </button>
          <button class="icon-button" type="button" aria-label="Menu">
            <svg viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
          </button>
        </div>
      </div>
    </header>

    <slot />

    <footer class="footer" id="footer">
      <div class="shell footer__inner">
        <div>
          <h3>CHINETECH</h3>
          <p>Le média qui décrypte l'innovation et l'écosystème technologique chinois.</p>
        </div>
        <div>
          <h4>Navigation</h4>
          <a href="/#top">Accueil</a>
          <a href="/#featured">À la une</a>
          <a href="/articles/">Tous les articles</a>
        </div>
        <div>
          <h4>Thématiques</h4>
          <a href="/#topics">IA & Robotique</a>
          <a href="/#topics">Semi-conducteurs</a>
          <a href="/#topics">Mobilité</a>
        </div>
        <div>
          <h4>Suivez-nous</h4>
          <div class="social" aria-label="Réseaux sociaux">
            <a href="#" aria-label="X"><svg viewBox="0 0 24 24"><path d="M18.9 2H22l-6.8 7.8L23 22h-6.1l-4.8-6.3L6.6 22H3.4l7.3-8.4L3.2 2h6.3l4.3 5.7L18.9 2Z"></path></svg></a>
            <a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24"><path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1-.02-5ZM3 10h4v11H3V10Zm7 0h3.8v1.5h.1c.5-.9 1.8-1.9 3.7-1.9 4 0 4.7 2.6 4.7 6V21h-4v-5c0-1.2 0-2.8-1.7-2.8s-2 1.3-2 2.7V21h-4V10Z"></path></svg></a>
            <a href="#" aria-label="YouTube"><svg viewBox="0 0 24 24"><path d="M21.6 7.2s-.2-1.6-.9-2.3c-.9-.9-1.9-.9-2.4-1C15 3.6 12 3.6 12 3.6h0s-3 0-6.3.3c-.5.1-1.5.1-2.4 1-.7.7-.9 2.3-.9 2.3S2.2 9.1 2.2 11v1.8c0 1.9.2 3.8.2 3.8s.2 1.6.9 2.3c.9.9 2.1.9 2.7 1 2 .2 6 .3 6 .3s3 0 6.3-.3c.5-.1 1.5-.1 2.4-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8V11c0-1.9-.2-3.8-.2-3.8ZM10.2 14.9V8.4l5.8 3.3-5.8 3.2Z"></path></svg></a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      document.documentElement.classList.add('js-ready');

      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      }, { threshold: 0.16 });

      document.querySelectorAll('.reveal').forEach((node) => {
        if (node.getBoundingClientRect().top < window.innerHeight * 0.92) {
          node.classList.add('is-visible');
        }
        observer.observe(node);
      });
    </script>
  </body>
</html>
